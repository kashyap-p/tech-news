// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Cached news article (optional cache — the app works without it on serverless).
/// On Vercel the filesystem is read-only, so this table only populates when a
/// writable DATABASE_URL (e.g. Postgres) is configured.
model Article {
  id          String   @id @default(cuid())
  /// Stable source id (e.g. devto:12345, hn:67890, web:<sha8>) — also used as
  /// the public id in API responses so the frontend works without this table.
  sourceId    String   @unique
  source      String   // "devto" | "hackernews" | "web"
  category    String   @default("tech") // "ai" | "tech" | "devto" | "hackernews" | "web"
  title       String
  description String   @default("")
  url         String
  image       String?
  author      String?
  publishedAt DateTime?
  aiSummary   String?
  aiTags      String?
  content     String?
  points      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([source])
  @@index([category])
  @@index([publishedAt])
}

/// Self-contained bookmark — stores the full article snapshot as JSON so it
/// works even when the Article table is unavailable (Vercel read-only FS).
model Bookmark {
  id        String   @id @default(cuid())
  sessionId String
  /// sourceId of the article (e.g. "devto:12345")
  articleKey String
  /// JSON snapshot of the article at bookmark time
  data      String
  createdAt DateTime @default(now())

  @@unique([sessionId, articleKey])
  @@index([sessionId])
}

/// Tracks share events for analytics. Self-contained (no FK).
model ShareEvent {
  id        String   @id @default(cuid())
  sessionId String
  articleKey String
  channel   String
  createdAt DateTime @default(now())

  @@index([articleKey])
}

/// Lightweight chatbot conversation log (session based, capped length).
model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String   // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
}
